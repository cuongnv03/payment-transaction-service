# Copy this file to .env and edit the values for your local stack.
#
#   cp .env.example .env
#
# .env is gitignored. docker compose reads it automatically.

# ── Database credentials ─────────────────────────────────────────────────────
DB_USERNAME=payment_user
DB_PASSWORD=payment_pass

# ── JWT signing secret ───────────────────────────────────────────────────────
# MUST be at least 32 characters (HS256 minimum). For a portfolio environment
# the default in docker-compose.yml is fine; for any real deployment set this.
# Generate one via:  openssl rand -base64 48
JWT_SECRET=change-this-secret-in-production-must-be-at-least-256-bits-long-for-hs256-algorithm
