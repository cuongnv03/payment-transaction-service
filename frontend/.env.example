# Optional override for the API base URL.
# Empty / unset → same-origin: the dev server (Vite) and the prod nginx
# both proxy /api/* and /actuator/* to the backend. This is the recommended
# setup; use this override only when you need to bypass the proxy
# (e.g. running the dev server against a remote backend).
#
# VITE_API_BASE_URL=http://localhost:8080
